# === Infrastructure ===
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_dev
REDIS_HOST=localhost
REDIS_PORT=6379
APICURIO_REGISTRY_URL=http://localhost:8085/apis/registry/v3

# === External API Keys (all free tier) ===
# NVD: Get free key at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
# GitHub: Personal Access Token (no special scopes needed)
GITHUB_PAT=
# GitHub Webhook Secret (for HMAC signature verification)
GITHUB_WEBHOOK_SECRET=

# === Service Ports ===
INGESTION_PORT=8081
ANALYSIS_PORT=8082
NOTIFICATION_PORT=8083
DASHBOARD_PORT=3000

# === Spring Profiles ===
# Set to 'demo' to enable demo data seeder
SPRING_PROFILES_ACTIVE=demo
